<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_retailit_stock_inventory">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="inv">
                <t t-set="inv" t-value="inv.with_context(lang=inv.env.user.lang or 'en_US')"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Inventory Adjustment</h2>
                        <h3 class="text-center"><span t-field="inv.name"/></h3>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Location:</strong> <span t-field="inv.location_id"/>
                            </div>
                            <div class="col-6">
                                <strong>Date:</strong> <span t-field="inv.date"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <strong>Type:</strong> <span t-field="inv.inventory_type"/>
                            </div>
                            <div class="col-6">
                                <strong>State:</strong> <span t-field="inv.state"/>
                            </div>
                        </div>

                        <h4 class="mt-4">All Lines</h4>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Lot/Serial</th>
                                    <th class="text-end">Theoretical</th>
                                    <th class="text-end">Counted</th>
                                    <th class="text-end">Difference</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="inv.line_ids" t-as="line">
                                    <tr>
                                        <td><span t-field="line.product_id"/></td>
                                        <td><span t-field="line.lot_id"/></td>
                                        <td class="text-end"><span t-field="line.theoretical_qty"/></td>
                                        <td class="text-end"><span t-field="line.product_qty"/></td>
                                        <td class="text-end"
                                            t-attf-class="#{'text-danger' if line.difference_qty &lt; 0 else 'text-success' if line.difference_qty &gt; 0 else ''}">
                                            <span t-esc="line.difference_qty"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <t t-if="inv.shortage_ids">
                            <h4 class="mt-4 text-danger">Shortages</h4>
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Lot/Serial</th>
                                        <th class="text-end">Theoretical</th>
                                        <th class="text-end">Counted</th>
                                        <th class="text-end">Shortage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="inv.shortage_ids" t-as="line">
                                        <tr>
                                            <td><span t-field="line.product_id"/></td>
                                            <td><span t-field="line.lot_id"/></td>
                                            <td class="text-end"><span t-field="line.theoretical_qty"/></td>
                                            <td class="text-end"><span t-field="line.product_qty"/></td>
                                            <td class="text-end text-danger">
                                                <span t-esc="abs(line.difference_qty)"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-if="inv.surplus_ids">
                            <h4 class="mt-4 text-success">Surpluses</h4>
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Lot/Serial</th>
                                        <th class="text-end">Theoretical</th>
                                        <th class="text-end">Counted</th>
                                        <th class="text-end">Surplus</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="inv.surplus_ids" t-as="line">
                                        <tr>
                                            <td><span t-field="line.product_id"/></td>
                                            <td><span t-field="line.lot_id"/></td>
                                            <td class="text-end"><span t-field="line.theoretical_qty"/></td>
                                            <td class="text-end"><span t-field="line.product_qty"/></td>
                                            <td class="text-end text-success">
                                                <span t-field="line.difference_qty"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <div class="row mt-4">
                            <div class="col-4">
                                <strong>Total Lines:</strong> <span t-esc="len(inv.line_ids)"/>
                            </div>
                            <div class="col-4">
                                <strong>Shortages:</strong> <span t-esc="len(inv.shortage_ids)"/>
                            </div>
                            <div class="col-4">
                                <strong>Surpluses:</strong> <span t-esc="len(inv.surplus_ids)"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
