<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="retailit_stock_inventory_cloud_import_wizard_form" model="ir.ui.view">
        <field name="name">retailit.stock.inventory.cloud.import.wizard.form</field>
        <field name="model">retailit.stock.inventory.cloud.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import from Beyond ID">
                <group>
                    <field name="inventory_id"/>
                    <field name="shop_code"/>
                    <field name="selected_count_id" invisible="1"/>
                    <field name="raw_reference" invisible="1"/>
                    <field name="count_line_count" invisible="1"/>
                    <field name="note" invisible="not note"/>
                </group>
                <notebook>
                    <page string="Available Inventories">
                        <field name="count_line_ids">
                            <list editable="bottom" create="0" delete="0" decoration-success="number_of_eans &gt; 0" decoration-muted="number_of_eans == 0">
                                <field name="is_selected" widget="boolean_toggle"/>
                                <field name="inventory_datetime" string="Date"/>
                                <field name="code"/>
                                <field name="reference" string="Reference"/>
                                <field name="number_of_eans" string="Products" sum="Products"/>
                                <field name="number_of_epcs" string="RFID Tags" sum="RFID Tags"/>
                                <field name="inventory_type" string="Type"/>
                                <field name="zone"/>
                                <field name="shop_code" column_invisible="1"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_search_inventories" string="Search Inventories" type="object" class="btn-secondary"/>
                    <button name="action_import" string="Import and Start Inventory" type="object" class="btn-primary" invisible="count_line_count == 0"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
