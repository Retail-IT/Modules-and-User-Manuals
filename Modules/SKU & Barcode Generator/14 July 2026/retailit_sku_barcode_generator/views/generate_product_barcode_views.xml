<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="retailit_generate_product_barcode_form_view" model="ir.ui.view">
        <field name="name">retailit.generate.product.barcode.form</field>
        <field name="model">retailit.generate.product.barcode</field>
        <field name="arch" type="xml">
            <form string="Product Barcode" groups="retailit_sku_barcode_generator.group_barcode_generator">
                <group>
                    <group colspan="2">
                        <field name="overwrite_existing" />
                    </group>
                </group>
                <footer>
                    <button string="Generate Barcode" name="generate_barcode" type="object" default_focus="1" class="btn-primary" />
                    <button string="Cancel" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="retailit_action_product_product_generate_barcode" model="ir.actions.act_window">
        <field name="name">Generate Barcode</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">retailit.generate.product.barcode</field>
        <field name="group_ids" eval="[(4, ref('retailit_sku_barcode_generator.group_barcode_generator'))]" />
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_product" />
    </record>

    <record id="retailit_action_product_template_generate_barcode" model="ir.actions.act_window">
        <field name="name">Generate Barcode</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">retailit.generate.product.barcode</field>
        <field name="group_ids" eval="[(4, ref('retailit_sku_barcode_generator.group_barcode_generator'))]" />
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template" />
    </record>

    <record id="retailit_action_product_generate_barcode_image" model="ir.actions.server">
        <field name="name">Generate Barcode Image</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_view_types">list</field>
        <field name="group_ids" eval="[(4, ref('retailit_sku_barcode_generator.group_barcode_generator'))]"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_generate_barcode_image_multi()
        </field>
    </record>

    <record id="retailit_action_template_generate_barcode_image" model="ir.actions.server">
        <field name="name">Generate Barcode Image</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="group_ids" eval="[(4, ref('retailit_sku_barcode_generator.group_barcode_generator'))]"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_generate_barcode_image_multi()
        </field>
    </record>

</odoo>
