<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_retailit_analytic_distribution_wizard_form" model="ir.ui.view">
<field name="name">retailit.analytic.distribution.wizard.form</field>
<field name="model">retailit.analytic.distribution.wizard</field>
<field name="arch" type="xml">
<form string="Apply Analytic Distribution">
<field name="statement_line_ids" invisible="1"/>
<div class="alert alert-info d-flex align-items-center" role="alert">
<span>
This distribution will be applied to the remaining balance of
<field name="statement_line_count" nolabel="1" class="oe_inline fw-bold"/>
selected transaction(s). Transactions that are already reconciled
will be skipped.
</span>
</div>
<group>
<field name="analytic_distribution" widget="analytic_distribution"/>
</group>
<footer>
<button name="action_apply" type="object" string="Apply" class="btn-primary"/>
<button special="cancel" string="Discard" class="btn-secondary"/>
</footer>
</form>
</field>
</record>

</odoo>
