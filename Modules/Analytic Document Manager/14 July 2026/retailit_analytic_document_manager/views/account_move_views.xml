<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="view_move_form_retailit_analytic_document_manager" model="ir.ui.view">
<field name="name">account.move.form.analytic.document.manager</field>
<field name="model">account.move</field>
<field name="inherit_id" ref="account.view_move_form"/>
<field name="arch" type="xml">
<xpath expr="//header" position="inside">
<button name="action_open_apply_analytic_wizard" string="Apply Analytic" type="object" class="btn-primary"/>
</xpath>
<xpath expr="//field[@name='ref']" position="after">
<field name="analytic_distribution" invisible="1"/>
</xpath>
</field>
</record>
</odoo>