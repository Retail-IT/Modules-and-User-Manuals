<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="view_sale_order_form_retailit_analytic_document_manager" model="ir.ui.view">
<field name="name">sale.order.form.analytic.document.manager</field>
<field name="model">sale.order</field>
<field name="inherit_id" ref="sale.view_order_form"/>
<field name="arch" type="xml">
<xpath expr="//header" position="inside">
<button name="action_apply_analytic_account" string="Apply Analytic" type="object" class="btn-primary"/>
</xpath>
<xpath expr="//field[@name='partner_id']" position="after">
<field name="analytic_distribution" widget="analytic_distribution"/>
</xpath>
</field>
</record>
</odoo>