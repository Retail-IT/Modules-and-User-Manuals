<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_retailit_analytic_distribution_move_wizard_form" model="ir.ui.view">
<field name="name">retailit.analytic.distribution.move.wizard.form</field>
<field name="model">retailit.analytic.distribution.move.wizard</field>
<field name="arch" type="xml">
<form string="Apply Analytic Distribution">
<field name="move_id" invisible="1"/>
<group>
<field name="analytic_distribution" widget="analytic_distribution"/>
</group>
<footer>
<button name="action_apply" type="object" string="Apply" class="btn-primary"/>
<button special="cancel" string="Discard" class="btn-secondary"/>
</footer>
</form>
</field>
</record>

</odoo>
