<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="retailit_beyondid_product_sync.ProductSyncProgress">
        <div class="o_beyondid_sync_progress">
            <div class="o_beyondid_sync_progress_header">
                <div>
                    <h2>Beyond ID Product Sync</h2>
                    <div class="o_beyondid_sync_progress_subtitle">
                        <span t-att-class="statusClass" t-esc="state.phase"/>
                    </div>
                </div>
                <div class="o_beyondid_sync_progress_actions">
                    <button class="btn btn-secondary" t-on-click="openHistory" t-att-disabled="isRunning">View History</button>
                    <button class="btn btn-primary" t-on-click="openProductSync" t-att-disabled="isRunning">Back to Product Sync</button>
                </div>
            </div>

            <div class="o_beyondid_sync_progress_body">
                <section class="o_beyondid_sync_progress_main">
                    <div class="o_beyondid_sync_progress_status">
                        <div>
                            <div class="o_beyondid_sync_progress_label">Current Process</div>
                            <div class="o_beyondid_sync_progress_message" t-esc="state.message"/>
                        </div>
                        <div class="o_beyondid_sync_progress_percent">
                            <span t-esc="state.percent"/>%
                        </div>
                    </div>

                    <div class="progress o_beyondid_sync_progress_bar" role="progressbar"
                         t-att-aria-valuenow="state.percent" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" t-att-style="progressStyle"/>
                    </div>

                    <div class="o_beyondid_sync_progress_steps">
                        <div>
                            <span class="o_beyondid_sync_progress_step_label">Batch</span>
                            <strong>
                                <t t-esc="state.currentBatch"/> / <t t-esc="state.totalBatches"/>
                            </strong>
                        </div>
                        <div t-if="state.totalSubBatches">
                            <span class="o_beyondid_sync_progress_step_label">Split</span>
                            <strong>
                                <t t-esc="state.currentSubBatch"/> / <t t-esc="state.totalSubBatches"/>
                            </strong>
                        </div>
                        <div>
                            <span class="o_beyondid_sync_progress_step_label">API Calls</span>
                            <strong t-esc="state.apiCalls"/>
                        </div>
                        <div>
                            <span class="o_beyondid_sync_progress_step_label">Retries</span>
                            <strong t-esc="state.retries"/>
                        </div>
                    </div>
                </section>

                <section class="o_beyondid_sync_progress_totals">
                    <div class="o_beyondid_sync_total">
                        <span>Evaluated</span>
                        <strong t-esc="state.totalEvaluated"/>
                    </div>
                    <div class="o_beyondid_sync_total">
                        <span>Sent</span>
                        <strong t-esc="state.totalSent"/>
                    </div>
                    <div class="o_beyondid_sync_total o_beyondid_sync_total_success">
                        <span>Synced</span>
                        <strong t-esc="state.totalSynced"/>
                    </div>
                    <div class="o_beyondid_sync_total o_beyondid_sync_total_warning">
                        <span>Warnings</span>
                        <strong t-esc="state.totalWarnings"/>
                    </div>
                    <div class="o_beyondid_sync_total o_beyondid_sync_total_danger">
                        <span>Failed</span>
                        <strong t-esc="state.totalFailed"/>
                    </div>
                    <div class="o_beyondid_sync_total">
                        <span>Skipped</span>
                        <strong t-esc="state.totalSkipped"/>
                    </div>
                    <div class="o_beyondid_sync_total">
                        <span>Unchanged</span>
                        <strong t-esc="state.totalNoChanges"/>
                    </div>
                </section>

                <section class="o_beyondid_sync_progress_log">
                    <div class="o_beyondid_sync_progress_log_title">Activity</div>
                    <div class="o_beyondid_sync_progress_log_entries">
                        <t t-if="state.log.length">
                            <t t-foreach="state.log" t-as="item" t-key="item.id">
                                <div class="o_beyondid_sync_progress_log_line">
                                    <span t-esc="item.timestamp"/>
                                    <p t-esc="item.message"/>
                                </div>
                            </t>
                        </t>
                        <div t-else="" class="o_beyondid_sync_progress_log_empty">
                            Waiting for the first sync event.
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </t>
</templates>
