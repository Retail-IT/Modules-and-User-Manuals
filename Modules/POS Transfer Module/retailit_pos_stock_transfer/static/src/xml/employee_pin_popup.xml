<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="retailit_pos_stock_transfer.TransferPinDialog">
        <Dialog title="props.title" size="'sm'">
            <div class="rtx-pin">
                <div class="rtx-pin-display" t-esc="maskedPin || 'Enter PIN'"/>
                <div class="rtx-pin-error" t-if="state.error" t-esc="state.error"/>
                <div class="rtx-pin-grid">
                    <t t-foreach="[1,2,3,4,5,6,7,8,9]" t-as="digit" t-key="digit">
                        <button class="rtx-pin-key" t-on-click="() => this.pressDigit(digit)" t-esc="digit"/>
                    </t>
                    <button class="rtx-pin-key rtx-pin-key-muted" t-on-click="pressBackspace">
                        <i class="fa fa-long-arrow-left"/>
                    </button>
                    <button class="rtx-pin-key" t-on-click="() => this.pressDigit(0)">0</button>
                    <button class="rtx-pin-key rtx-pin-key-primary" t-on-click="confirm" t-att-disabled="state.loading">
                        <i class="fa fa-check"/>
                    </button>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">Cancel</button>
            </t>
        </Dialog>
    </t>
</templates>
